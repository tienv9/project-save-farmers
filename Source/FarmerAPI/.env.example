# SQL Server SA password — must be 8+ chars, mix of upper/lower/digit/symbol
SA_PASSWORD=YourStrongPassword123!

# JWT settings — copy values from your current EB environment variables
JWT_ISSUER=https://your-domain.com
JWT_AUDIENCE=https://your-domain.com
JWT_KEY=your-super-secret-jwt-key-at-least-32-chars
JWT_EXPIRES=10000000
